<Window x:Class="WindowsAudioSwitcher.Notifications.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        Width="360"
        Opacity="0"
        Focusable="False"
        ShowActivated="False">
    <!-- Mirrors the "Currently routing" header card in MainWindow: opaque dark
         surface, frost-edge border, status dot + small uppercase label + bold
         device name. Toasts are opaque (no Mica because there's no FluentWindow
         parent), so we lean on a heavier drop shadow for separation from the
         desktop wallpaper. -->
    <Border Background="{StaticResource SurfaceElevatedBrush}"
            BorderBrush="{StaticResource BorderBrushStrong}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="14">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Ellipse Grid.Column="0"
                     Width="10" Height="10"
                     Fill="{StaticResource StatusGoodBrush}"
                     VerticalAlignment="Center"
                     Margin="0,0,14,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontWeight="SemiBold"
                           FontSize="10"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="MessageText"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
